{
  "name": "mango",
  "displayName": "Mango — Get Paid to Code",
  "description": "Turn AI coding wait-time into passive income. A small brand message appears in your status bar while your agent works, and you keep 90% of the revenue. Same account as the CLI; cash out via Stripe.",
  "version": "1.0.0",
  "publisher": "bggprogramming",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bggprogramming/mango"
  },
  "homepage": "https://bggprogramming.github.io/mango/",
  "bugs": {
    "url": "https://github.com/bggprogramming/mango/issues"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Other"],
  "keywords": ["earnings", "passive income", "rewards", "cashback", "developer", "side income"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#FFF3E0",
    "theme": "light"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mango.openAd",
        "title": "Mango: Open current sponsor"
      },
      {
        "command": "mango.showEarnings",
        "title": "Mango: Show earnings"
      }
    ]
  }
}
